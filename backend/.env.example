# Railway will auto-inject these from linked services:
DATABASE_URL=jdbc:postgresql://host:5432/wanderlust
DATABASE_USERNAME=wanderlust
DATABASE_PASSWORD=secret

REDIS_URL=redis://default:secret@host:6379

KEYCLOAK_ISSUER_URI=https://your-keycloak.up.railway.app/realms/wanderlust
KEYCLOAK_JWK_URI=https://your-keycloak.up.railway.app/realms/wanderlust/protocol/openid-connect/certs

FRONTEND_URL=https://your-frontend.up.railway.app

# Cloudflare R2 or MinIO on Railway
S3_ENDPOINT=https://your-s3-endpoint
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=wanderlust-media
S3_REGION=auto
CDN_BASE_URL=https://your-cdn-url/wanderlust-media

SPRING_PROFILES_ACTIVE=prod
